---
import Layout from '~/layouts/Layout.astro';
import { getHomePermalink, getBlogPermalink } from '~/utils/permalinks';

const title = `找不到頁面 — 404`;
---

<Layout metadata={{ title, robots: { index: false, follow: true } }}>
  <section class="flex items-center h-full p-16">
    <div class="container flex flex-col items-center justify-center px-5 mx-auto my-8">
      <div class="max-w-md text-center">
        <h2 class="mb-8 font-bold text-9xl">
          <span class="sr-only">錯誤</span>
          <span class="text-primary">404</span>
        </h2>
        <p class="text-3xl font-semibold md:text-3xl">抱歉,找不到這個頁面。</p>
        <p class="mt-4 mb-8 text-lg text-muted dark:text-slate-400">
          別擔心,你可以從首頁或部落格繼續逛逛。
        </p>
        <div class="flex flex-wrap justify-center gap-4">
          <a rel="noopener noreferrer" href={getHomePermalink()} class="btn">回首頁</a>
          <a rel="noopener noreferrer" href={getBlogPermalink()} class="btn btn-primary">前往部落格</a>
        </div>
      </div>
    </div>
  </section>
</Layout>
